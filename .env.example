# WaterbearIntl - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ===================== SERVER =====================
PORT=3000

# ===================== SECURITY =====================
# JWT secret for admin authentication (auto-generated if empty, but set it explicitly for production)
JWT_SECRET=

# Admin panel default password (change immediately in production)
ADMIN_PASSWORD=

# ===================== PAYPAL (Sandbox) =====================
# Get these from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayPal API base URL (sandbox default, change to https://api-m.paypal.com for production)
PAYPAL_API=https://api-m.sandbox.paypal.com

# ===================== STRIPE (Optional) =====================
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# ===================== EMAIL (Optional) =====================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@waterbearintl.com